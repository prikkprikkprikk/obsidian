views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "Oppgaver"
    order:
      - file.name
      - Prosjekt
      - Hvem
      - Oppgavestatus
    sort:
      - property: Oppgavestatus
        direction: DESC
  - type: table
    name: Dette prosjektet
    filters:
      and:
        - file.folder == "Prosjekt.contains(this)"
    order:
      - file.name
      - Prosjekt
      - Hovedprosjekt
    rowHeight: tall
  - type: cards
    name: Kort
